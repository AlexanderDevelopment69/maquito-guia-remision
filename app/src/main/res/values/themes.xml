<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Maquitop" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/naranja_primario</item>
        <item name="colorPrimaryVariant">@color/naranja_oscuro</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">@color/azul_oscuro</item>
        <item name="colorOnSecondary">@android:color/white</item>
        <item name="colorSurface">@color/fondo_card</item>
        <item name="colorOnSurface">@color/texto_principal</item>
        <item name="colorError">#B00020</item>
        <item name="android:windowBackground">@color/fondo_principal</item>
        <item name="android:statusBarColor">@color/naranja_oscuro</item>
        <item name="android:navigationBarColor">@android:color/white</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/white</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.Maquitop</item>
    </style>
</resources>
