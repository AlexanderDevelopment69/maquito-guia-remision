<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    android:layout_marginBottom="10dp"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Ícono izquierdo -->
        <TextView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="📋"
            android:textSize="24sp"
            android:gravity="center"
            android:background="@drawable/bg_icon_azul"
            android:layout_marginEnd="14dp" />

        <!-- Datos -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvGuiaNumero"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="G-202401-0001"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/azul_primario" />

            <TextView
                android:id="@+id/tvGuiaCliente"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cliente"
                android:textSize="13sp"
                android:textColor="@color/texto_principal"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvGuiaEquipo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Equipo"
                android:textSize="12sp"
                android:textColor="@color/texto_secundario"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvGuiaFecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01/01/2024"
                android:textSize="11sp"
                android:textColor="@color/texto_secundario"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Indicador PDF -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/ivPdfIndicator"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_share"
                android:tint="@color/azul_primario"
                android:visibility="invisible"
                android:contentDescription="PDF generado" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textSize="22sp"
                android:textColor="@color/texto_secundario"
                android:layout_marginTop="4dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
